{
  "extends": ["stylelint-config-standard", "stylelint-config-tailwindcss"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": ["tailwind", "apply", "layer", "utility", "config"]
      }
    ],
    "selector-class-pattern": null,
    "custom-property-pattern": null,
    "media-feature-range-notation": null,

    "keyframes-name-pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
    "no-descending-specificity": true,
    "declaration-block-no-redundant-longhand-properties": [
      true,
      {
        "ignoreLonghands": [
          "padding-block",
          "padding-inline",
          "margin-block",
          "margin-inline"
        ]
      }
    ],
    "alpha-value-notation": "number",
    "color-function-notation": "modern",
    "selector-no-vendor-prefix": true,
    "property-no-vendor-prefix": [
      true,
      { "ignoreProperties": ["background-clip"] }
    ],

    "length-zero-no-unit": true,
    "number-max-precision": 4,
    "color-hex-length": "short",
    "shorthand-property-no-redundant-values": true,
    "block-no-empty": true,
    "comment-no-empty": true,
    "declaration-block-no-shorthand-property-overrides": true,
    "no-duplicate-at-import-rules": true,
    "property-no-unknown": true,
    "selector-pseudo-class-no-unknown": true,
    "function-no-unknown": [true, { "ignoreFunctions": ["theme"] }],
    "no-invalid-double-slash-comments": true,
    "no-irregular-whitespace": true,
    "font-family-no-missing-generic-family-keyword": true,
    "font-family-no-duplicate-names": true,
    "declaration-block-no-duplicate-custom-properties": true,
    "declaration-block-no-duplicate-properties": [
      true,
      {
        "ignore": ["consecutive-duplicates-with-different-syntaxes"]
      }
    ],
    "value-keyword-case": "lower",
    "function-name-case": "lower",
    "at-rule-no-vendor-prefix": true,
    "media-feature-name-no-vendor-prefix": true,
    "selector-pseudo-element-colon-notation": "double",
    "selector-type-case": "lower",
    "selector-not-notation": "complex",
    "hue-degree-notation": "angle",
    "lightness-notation": "percentage",
    "color-function-alias-notation": "without-alpha",
    "font-family-name-quotes": "always-where-recommended",
    "function-url-quotes": "always",
    "selector-attribute-quotes": "always",
    "value-no-vendor-prefix": [true, { "ignoreValues": ["box", "inline-box"] }],
    "property-no-deprecated": true,
    "at-rule-no-deprecated": true,
    "declaration-property-value-keyword-no-deprecated": true,
    "media-type-no-deprecated": true,
    "comment-whitespace-inside": "always",
    "string-no-newline": [
      true,
      { "ignore": ["at-rule-preludes", "declaration-values"] }
    ],
    "keyframe-declaration-no-important": true,
    "keyframe-block-no-duplicate-selectors": true,
    "nesting-selector-no-missing-scoping-root": true,
    "selector-pseudo-element-no-unknown": true,
    "selector-type-no-unknown": [true, { "ignore": ["custom-elements"] }],
    "named-grid-areas-no-invalid": true,
    "media-feature-name-no-unknown": true,
    "media-query-no-invalid": true,
    "no-invalid-position-at-import-rule": true,
    "no-invalid-position-declaration": true,
    "no-empty-source": true,
    "block-no-redundant-nested-style-rules": true,
    "custom-property-no-missing-var-function": true,
    "selector-anb-no-unmatchable": true,
    "declaration-block-single-line-max-declarations": 1,
    "rule-empty-line-before": [
      "always-multi-line",
      {
        "except": ["first-nested"],
        "ignore": ["after-comment"]
      }
    ],
    "at-rule-empty-line-before": [
      "always",
      {
        "except": ["blockless-after-same-name-blockless", "first-nested"],
        "ignore": ["after-comment"]
      }
    ],
    "comment-empty-line-before": [
      "always",
      {
        "except": ["first-nested"],
        "ignore": ["stylelint-commands"]
      }
    ],
    "keyframe-selector-notation": "percentage-unless-within-keyword-only-block",
    "container-name-pattern": "^(--)?([a-z][a-z0-9]*)(-[a-z0-9]+)*$",
    "custom-media-pattern": "^([a-z][a-z0-9]*)(-[a-z0-9]+)*$",
    "layer-name-pattern": "^([a-z][a-z0-9]*)([.-][a-z0-9]+)*$",
    "selector-id-pattern": "^([a-z][a-z0-9]*)(-[a-z0-9]+)*$",
    "syntax-string-no-invalid": true,
    "annotation-no-unknown": true,
    "at-rule-descriptor-no-unknown": true,
    "at-rule-descriptor-value-no-unknown": true,
    "at-rule-prelude-no-invalid": [true, { "ignoreAtRules": ["media"] }],
    "media-feature-name-value-no-unknown": true
  }
}
