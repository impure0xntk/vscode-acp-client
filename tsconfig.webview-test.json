{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "outDir": "out/webview-test",
    "rootDir": "webview-src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": [
    "webview-src/test/**/*",
    "webview-src/store/sessionStore.ts",
    "webview-src/store/messageStore.ts",
    "webview-src/store/scrollStateStore.ts",
    "webview-src/store/selectors.ts",
    "webview-src/store/mappers.ts",
    "webview-src/components/toolbar/formatting.ts",
    "webview-src/components/toolbar/DetailSections.tsx",
    "webview-src/components/ui/Chip.ts",
    "webview-src/components/ui/Chip.tsx",
    "webview-src/shared/elapsedColor.ts",
    "webview-src/shared/constants.ts",
    "webview-src/types.ts",
    "webview-src/lib/logger.ts",
    "webview-src/lib/icons.tsx",
    "webview-src/lib/vscodeApi.ts",
    "webview-src/hooks/useSessionInfo.ts",
    "webview-src/hooks/useSessionUnreadCount.ts",
    "webview-src/hooks/useMessages.ts",
    "webview-src/hooks/useMessagePipeline.ts",
    "webview-src/hooks/useScrollController.ts",
    "webview-src/hooks/useLogger.ts",
    "webview-src/pipeline/**/*",
    "webview-src/util/toolBatchSummary.ts",
    "webview-src/components/SessionOverview/SessionOverviewCardBase.tsx",
    "webview-src/components/ContextCompressionNotice.tsx",
    "webview-src/components/CompletionNotification.tsx",
    "webview-src/components/ModePicker.tsx",
    "webview-src/components/SessionOverview/SessionOverviewToolbar.tsx",
    "webview-src/components/UserJumpNav.tsx",
    "webview-src/components/ui/UnreadBadge.tsx",
    "webview-src/components/StatusIcon.tsx",
    "webview-src/components/SessionHistory/SessionList.tsx",
    "webview-src/components/SessionHistory/DetailModal.tsx",
    "webview-src/components/SessionHistory/index.tsx"
  ],
  "exclude": ["node_modules", "out", "dist"]
}
